.gallery,page{min-height:100vh}page{font-family:"Hiragino Sans GB","Hiragino Sans GB W3","Microsoft YaHei","WenQuanYi Micro Hei",sans-serif;background-color:#f5f7f9}scroll-view,text,view{-webkit-box-sizing:border-box;box-sizing:border-box}button:after{display:none}.gallery{background-color:#fff;padding:10rpx}.gallery .title{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;text-align:center;margin:100rpx 0}.gallery .title .description,.gallery .title .name{display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden}.gallery .title .name{-webkit-line-clamp:1;font-size:1.5rem;font-weight:700;margin-bottom:20rpx}.gallery .title .description{-webkit-line-clamp:2;color:#555}.gallery .grid{display:grid;grid-template-columns:repeat(2,1fr);grid-gap:10rpx}.gallery .grid .photo{width:100%;height:calc((100vw - 30rpx)/2)}